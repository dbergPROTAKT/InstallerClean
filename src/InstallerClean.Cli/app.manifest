<?xml version="1.0" encoding="utf-8"?>
<assembly manifestVersion="1.0" xmlns="urn:schemas-microsoft-com:asm.v1">
  <!-- assemblyIdentity is advisory; Windows ignores it for trust.
       Version matches Directory.Build.props <Version>. -->
  <assemblyIdentity version="1.8.2.0" name="InstallerClean.cli"/>
  <trustInfo xmlns="urn:schemas-microsoft-com:asm.v2">
    <security>
      <requestedPrivileges xmlns="urn:schemas-microsoft-com:asm.v3">
        <requestedExecutionLevel level="requireAdministrator" uiAccess="false" />
      </requestedPrivileges>
    </security>
  </trustInfo>
  <compatibility xmlns="urn:schemas-microsoft-com:compatibility.v1">
    <application>
      <!-- Windows 10 and 11. Microsoft never published a separate
           compatibility GUID for Windows 11; apps target the Windows 10
           GUID and Windows reports them as compatible with Windows 11
           automatically. The 8e0f7a12 GUID covers both. -->
      <supportedOS Id="{8e0f7a12-bfb3-4fe8-b9a5-48fd50a15a9a}"/>
    </application>
  </compatibility>
  <application xmlns="urn:schemas-microsoft-com:asm.v3">
    <windowsSettings>
      <!-- longPathAware so File.Move / Path.GetFullPath honour paths
           past MAX_PATH (260 chars). DPI settings deliberately omitted
           on the CLI: a console process has no windows, so dpiAware and
           dpiAwareness affect nothing. -->
      <longPathAware xmlns="http://schemas.microsoft.com/SMI/2016/WindowsSettings">true</longPathAware>
    </windowsSettings>
  </application>
</assembly>
