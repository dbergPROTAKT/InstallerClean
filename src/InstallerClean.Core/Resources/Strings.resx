  <!-- ============================================================
       CLI OUTPUT
       Console messages emitted by installerclean-cli.exe. Localised
       so non-English sysadmins reading scripted output get text
       matching their UI culture.
       ============================================================ -->
  <data name="Cli.UnknownArgument" xml:space="preserve"><value>Unknown argument: {0}</value></data>
  <data name="Cli.Cancelling" xml:space="preserve"><value>Cancelling...</value></data>
  <data name="Cli.Cancelled" xml:space="preserve"><value>Cancelled.</value></data>
  <!-- 0 = exception type name (full message + stack trace go to the
       crash log; the CLI runs elevated so .Message could include paths
       from another user's profile if logged to a shared file).
       1 = crash log path. -->
  <data name="Cli.GenericError" xml:space="preserve"><value>Error: {0}. Details written to {1}.</value></data>
  <data name="Cli.GenericError.NoLog" xml:space="preserve"><value>Error: {0}. The crash log could not be written.</value></data>
  <data name="Cli.ScanningInstaller" xml:space="preserve"><value>Scanning C:\Windows\Installer...</value></data>
  <!-- 0 = file count, 1 = pluralised noun, 2 = size display -->
  <data name="Cli.FoundOrphans" xml:space="preserve"><value>Found {0} {1} to clean up ({2}).</value></data>
  <data name="Cli.NothingToDo" xml:space="preserve"><value>Nothing to do.</value></data>
  <!-- 0 = mode arg ("/s"), 1 = registered package count, 2 = pluralised "package"/"packages" -->
  <data name="Cli.EventLogScanNoOrphans" xml:space="preserve"><value>Scan mode ({0}): no orphaned files. Installer database has {1} registered {2}.</value></data>
  <!-- 0 = mode arg ("/s"), 1 = file count, 2 = pluralised noun, 3 = size display -->
  <data name="Cli.EventLogScanFound" xml:space="preserve"><value>Scan mode ({0}): {1} orphaned {2} found, {3}. No action taken.</value></data>
  <!-- 0 = file count, 1 = pluralised noun "file"/"files" -->
  <data name="Cli.DeletingFiles" xml:space="preserve"><value>Deleting {0} {1}...</value></data>
  <!-- 0 = deleted count, 1 = pluralised noun -->
  <data name="Cli.DeletedFiles" xml:space="preserve"><value>Deleted {0} {1}.</value></data>
  <!-- 0 = mode arg ("/d"), 1 = deleted count, 2 = total count, 3 = pluralised noun,
       4 = size display, 5 = error count, 6 = pluralised "error"/"errors" -->
  <data name="Cli.EventLogDeleteSummary" xml:space="preserve"><value>{0} mode: {1} of {2} {3} sent to the Recycle Bin, {4} recovered, {5} {6}.</value></data>
  <data name="Cli.NoMoveDestination" xml:space="preserve"><value>Error: no move destination specified. Use /m PATH or set a default in the GUI.</value></data>
  <data name="Cli.EventLogMoveNoDestination" xml:space="preserve"><value>{0} mode aborted: no destination specified.</value></data>
  <data name="Cli.MoveDestinationInsideInstaller" xml:space="preserve"><value>Error: destination cannot be inside the Windows Installer folder.</value></data>
  <!-- 0 = destination -->
  <data name="Cli.EventLogMoveDestinationInsideInstaller" xml:space="preserve"><value>{0} mode aborted: destination {1} is inside C:\Windows\Installer.</value></data>
  <data name="Cli.PendingRebootBlocked.MsiExecuteMutex" xml:space="preserve"><value>Error: Windows Installer is currently processing an installation. Move and Delete are blocked until it finishes. Try again once it completes.</value></data>
  <data name="Cli.PendingRebootBlocked.InstallerInProgress" xml:space="preserve"><value>Error: a previous Windows Installer transaction is suspended on this machine. Resume or roll back that install (or restart Windows) before cleaning the cache.</value></data>
  <!-- 0 = matched path under %SystemRoot%\Installer that triggered the gate -->
  <data name="Cli.PendingRebootBlocked.PendingRenameInCache" xml:space="preserve"><value>Error: a queued post-reboot file operation targets the Installer cache ({0}). Restart Windows to complete that operation before cleaning.</value></data>
  <data name="Cli.PendingRebootBlocked.Generic" xml:space="preserve"><value>Error: cache cleanup is blocked by a pending Windows Installer state. Restart Windows and run again.</value></data>
  <!-- 0 = arg ("/d" or "/m"), 1 = reason name (MsiExecuteMutexHeld/InstallerInProgress/PendingRenameInCache), 2 = detail (matched path for PendingRenameInCache, otherwise empty) -->
  <data name="Cli.EventLogPendingRebootBlocked" xml:space="preserve"><value>{0} mode aborted: pending reboot detected, reason: {1}. {2}</value></data>
  <!-- 0 = file count, 1 = pluralised noun "file"/"files", 2 = destination -->
  <data name="Cli.MovingFiles" xml:space="preserve"><value>Moving {0} {1} to {2}...</value></data>
  <!-- 0 = moved count, 1 = pluralised noun -->
  <data name="Cli.MovedFiles" xml:space="preserve"><value>Moved {0} {1}.</value></data>
  <!-- 0 = mode arg ("/m"), 1 = moved count, 2 = total count, 3 = pluralised noun,
       4 = destination, 5 = size display, 6 = error count, 7 = pluralised "error"/"errors" -->
  <data name="Cli.EventLogMoveSummary" xml:space="preserve"><value>{0} mode: {1} of {2} {3} moved to {4}, {5} relocated, {6} {7}.</value></data>
  <data name="Cli.EventLogCancelledPartial" xml:space="preserve"><value>{0} mode interrupted by Ctrl+C: {1} of {2} {3} processed before cancellation. See progress output for the per-file detail.</value></data>

  <!-- ============================================================
       CLI HELP TEXT (printed by /? -? /h)
       ============================================================ -->
  <data name="Cli.Help.Header" xml:space="preserve"><value>InstallerClean - clean up C:\Windows\Installer</value></data>
  <data name="Cli.Help.Usage" xml:space="preserve"><value>Usage:</value></data>
  <data name="Cli.Help.Help" xml:space="preserve"><value>  installerclean-cli /?       Show this help</value></data>
  <data name="Cli.Help.ScanOnly" xml:space="preserve"><value>  installerclean-cli /s       Scan only - list removable files</value></data>
  <data name="Cli.Help.Delete" xml:space="preserve"><value>  installerclean-cli /d       Delete removable files (Recycle Bin)</value></data>
  <data name="Cli.Help.MoveDefault" xml:space="preserve"><value>  installerclean-cli /m       Move to saved default location</value></data>
  <data name="Cli.Help.MovePath" xml:space="preserve"><value>  installerclean-cli /m PATH  Move to specified path</value></data>
  <data name="Cli.Help.NoteLine1" xml:space="preserve"><value>installerclean-cli is a real console process and blocks the prompt</value></data>
  <data name="Cli.Help.NoteLine2" xml:space="preserve"><value>until it finishes; redirect or pipe its output as you would any</value></data>
  <data name="Cli.Help.NoteLine3" xml:space="preserve"><value>other console exe. The GUI lives in InstallerClean.exe alongside it.</value></data>
  <data name="Cli.Help.ExitCodesHeader" xml:space="preserve"><value>Exit codes:</value></data>
  <data name="Cli.Help.ExitCodeOk" xml:space="preserve"><value>  0   success: every flagged file was processed</value></data>
  <data name="Cli.Help.ExitCodePartial" xml:space="preserve"><value>  2   partial: some files processed, some failed</value></data>
  <data name="Cli.Help.ExitCodeError" xml:space="preserve"><value>  1   failure: nothing processed (bad args, scan failed, all files failed)</value></data>
  <data name="Cli.Help.ExitCodeCancelled" xml:space="preserve"><value>  130 cancelled (Ctrl+C)</value></data>

