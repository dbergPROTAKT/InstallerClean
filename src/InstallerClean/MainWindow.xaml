<Window x:Class="InstallerClean.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:InstallerClean.Resources"
        Title="{loc:Translate Window.Main.Title}"
        Width="720" Height="480"
        MinWidth="520" MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Surface.Sidebar}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" GlassFrameThickness="-1"
                      ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding Scan.ScanCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar. Row 0 height matches WindowChrome.CaptionHeight (32)
             so the icon and the 32px caption buttons share a centerline.
             Left margin (16) matches where the detail windows' title bars
             land (DetailWindowMargin 24 + StackPanel -8). -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="16,0,0,0">
            <Image Source="Assets/splash-icon.png" Width="16" Height="16"
                   RenderOptions.BitmapScalingMode="HighQuality" Margin="{StaticResource GapRight.Sm}"/>
            <TextBlock Text="{loc:Translate Window.Main.Title}" Foreground="{StaticResource Text.Body}"
                       FontSize="{StaticResource Type.Heading.Sm}" FontWeight="Medium"/>
        </StackPanel>
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Top">
            <Button Style="{StaticResource CaptionButton}" Content="&#xE921;"
                    Click="MinimizeClick" AutomationProperties.Name="{loc:Translate Automation.Minimise}"
                    ToolTip="{loc:Translate Tooltip.Minimise}"/>
            <Button Style="{StaticResource CaptionCloseButton}" Content="&#xE8BB;"
                    Click="CloseClick" AutomationProperties.Name="{loc:Translate Automation.Close}"
                    ToolTip="{loc:Translate Tooltip.Close}"/>
        </StackPanel>

        <Grid Grid.Row="1" Grid.RowSpan="2" Margin="24,0,24,48" VerticalAlignment="Center"
              MaxWidth="720" HorizontalAlignment="Center"
              IsEnabled="{Binding IsMainContentInteractive}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Context: scan results ──────────────────────── -->
            <StackPanel Grid.Row="0">

                <!-- Explanatory text -->
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Text.Muted}" FontSize="{StaticResource Type.Body}" Margin="{StaticResource GapBottom.Lg}"
                           Text="{loc:Translate Body.MainExplanation}"/>

                <!-- Pending reboot warning (Phosphor fill, tweaked !) -->
                <StackPanel Orientation="Horizontal" Margin="{StaticResource GapBottom.Lg}"
                            Visibility="{Binding Scan.HasPendingReboot, Converter={StaticResource BoolToVis}}">
                    <Path Data="M236.8,188.09,149.35,36.22h0a24.76,24.76,0,0,0-42.7,0L19.2,188.09a23.51,23.51,0,0,0,0,23.72A24.35,24.35,0,0,0,40.55,224h174.9a24.35,24.35,0,0,0,21.33-12.19A23.51,23.51,0,0,0,236.8,188.09ZM118,98a10,10,0,0,1,20,0v46a10,10,0,0,1,-20,0Zm10,96a14,14,0,1,1,14,-14A14,14,0,0,1,128,194Z"
                          Fill="{StaticResource Status.Warning}" Width="16" Height="16" Stretch="Uniform"
                          VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding Scan.PendingRebootBannerText}"
                               Foreground="{StaticResource Text.Body}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Registered files missing from disk -->
                <StackPanel Orientation="Horizontal" Margin="{StaticResource GapBottom.Lg}"
                            Visibility="{Binding Scan.HasMissingFromDisk, Converter={StaticResource BoolToVis}}">
                    <Path Data="M236.8,188.09,149.35,36.22h0a24.76,24.76,0,0,0-42.7,0L19.2,188.09a23.51,23.51,0,0,0,0,23.72A24.35,24.35,0,0,0,40.55,224h174.9a24.35,24.35,0,0,0,21.33-12.19A23.51,23.51,0,0,0,236.8,188.09ZM118,98a10,10,0,0,1,20,0v46a10,10,0,0,1,-20,0Zm10,96a14,14,0,1,1,14,-14A14,14,0,0,1,128,194Z"
                          Fill="{StaticResource Status.Warning}" Width="16" Height="16" Stretch="Uniform"
                          VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding Scan.MissingFromDiskSummaryText}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Text.Body}" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Still used -->
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                               Foreground="{StaticResource Text.Muted}" FontSize="{StaticResource Type.Heading.Sm}"
                               Text="{Binding Scan.RegisteredSummaryText}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Scan.RegisteredSizeDisplay}"
                               Foreground="{StaticResource Text.Muted}" FontSize="{StaticResource Type.Heading.Sm}"
                               VerticalAlignment="Center" MinWidth="72" TextAlignment="Right"
                               Margin="12,0"/>
                    <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource GhostPill}"
                            Content="{loc:Translate Action.Details}" Command="{Binding Chrome.OpenRegisteredDetailsCommand}"
                            Height="28" Padding="12,0" FontSize="{StaticResource Type.Heading.Sm}"
                            VerticalAlignment="Center" Margin="{StaticResource GapLeft.Md}"
                            FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                            AutomationProperties.Name="{loc:Translate Automation.ViewRegisteredFiles}"/>
                </Grid>

            </StackPanel>

            <!-- ── Separator ────────────────────────────────────── -->
            <Border Grid.Row="2" BorderBrush="{StaticResource Action.Primary.Background}" BorderThickness="0,1,0,0"/>

            <!-- ── Action zone: orphaned + move/delete ──────────── -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Orphaned -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Heading.Sm}"
                               Text="{Binding Scan.OrphanedSummaryText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Scan.OrphanedSizeDisplay}"
                               Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Heading.Sm}"
                               VerticalAlignment="Center" MinWidth="72" TextAlignment="Right"
                               Margin="12,0"/>
                    <Button Grid.Column="2" Style="{StaticResource GhostPill}"
                            Content="{loc:Translate Action.Details}" Command="{Binding Chrome.OpenOrphanedDetailsCommand}"
                            Height="28" Padding="12,0" FontSize="{StaticResource Type.Heading.Sm}"
                            VerticalAlignment="Center" Margin="{StaticResource GapLeft.Md}"
                            FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                            AutomationProperties.Name="{loc:Translate Automation.ViewOrphanedFiles}"/>
                </Grid>

                <!-- Move location label -->
                <TextBlock Grid.Row="2" Text="{loc:Translate Section.Move.Location}"
                           Foreground="{StaticResource Text.Body}" FontSize="{StaticResource Type.Heading.Sm}"/>

                <!-- Move destination -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox Style="{StaticResource PillTextBox}"
                                 Text="{Binding Cleanup.MoveDestination, Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="{loc:Translate Automation.MoveDestinationFolder}"
                                 ToolTip="{loc:Translate Tooltip.MoveDestination}"/>
                        <TextBlock Text="{loc:Translate Action.MoveDestinationPlaceholder}"
                                   Foreground="{StaticResource Text.Muted}" FontSize="{StaticResource Type.Body}" FontStyle="Italic"
                                   Padding="12,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Cleanup.MoveDestination}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button Grid.Column="2" Style="{StaticResource PrimaryPill}"
                            Content="{loc:Translate Action.Browse}" Command="{Binding Cleanup.BrowseDestinationCommand}"/>
                </Grid>

                <!-- Buttons row -->
                <DockPanel Grid.Row="6">
                    <Button DockPanel.Dock="Right" Style="{StaticResource AccentPill}"
                            Content="{loc:Translate Action.Move}" Command="{Binding Cleanup.MoveAllCommand}"
                            AutomationProperties.HelpText="{loc:Translate Automation.MoveAllFiles}"
                            ToolTip="{loc:Translate Tooltip.Move}"
                            ToolTipService.ShowOnDisabled="True"/>

                    <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryPill}"
                            Content="{loc:Translate Action.Delete}" Command="{Binding Cleanup.DeleteAllCommand}"
                            AutomationProperties.HelpText="{loc:Translate Automation.DeleteAllFiles}"
                            ToolTip="{loc:Translate Tooltip.Delete}"
                            ToolTipService.ShowOnDisabled="True"
                            Margin="{StaticResource GapRight.Sm}"/>

                    <TextBlock DockPanel.Dock="Left" Text="{Binding Cleanup.OperationProgress}"
                               VerticalAlignment="Center" Foreground="{StaticResource Text.Muted}"
                               FontSize="{StaticResource Type.Body}"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Grid>

        </Grid>

        <!-- ── Bottom nav ────────────────────────────────────── -->
        <DockPanel Grid.Row="3" LastChildFill="False" Margin="4,8,24,8"
                   IsEnabled="{Binding IsMainContentInteractive}">
            <Button DockPanel.Dock="Left" Style="{StaticResource GhostPill}"
                    Content="{loc:Translate Action.Rescan}" Command="{Binding Scan.ScanCommand}"/>
            <Button DockPanel.Dock="Left" Style="{StaticResource GhostPill}"
                    Content="{loc:Translate Action.About}" Command="{Binding Chrome.ShowAboutCommand}" Margin="4,0,0,0"/>
            <Button DockPanel.Dock="Right" Style="{StaticResource GhostPill}"
                    Command="{Binding Chrome.DonateCommand}"
                    AutomationProperties.Name="{loc:Translate Automation.BuyMeACuppa}"
                    FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                    ToolTipService.InitialShowDelay="0"
                    Padding="6,0" Height="28">
                <Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                      Fill="{StaticResource Decoration.Heart}" Width="18" Height="18" Stretch="Uniform"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Path.RenderTransform>
                    <Path.Style>
                        <Style TargetType="Path">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1.2" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1.2" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1.0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource WarningTooltip}" Content="{loc:Translate Tooltip.BuyMeACuppa}"/>
                </Button.ToolTip>
            </Button>
            <Button DockPanel.Dock="Right" Style="{StaticResource GhostPill}"
                    Command="{Binding Chrome.StarOnGitHubCommand}"
                    AutomationProperties.Name="{loc:Translate Automation.LeaveStarOnGitHub}"
                    FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                    ToolTipService.InitialShowDelay="0"
                    Padding="6,0" Height="28" Margin="{StaticResource GapRight.Md}">
                <Path Data="m12.672.668 3.059 6.197 6.838.993a.75.75 0 0 1 .416 1.28l-4.948 4.823 1.168 6.812a.75.75 0 0 1-1.088.79L12 18.347l-6.116 3.216a.75.75 0 0 1-1.088-.791l1.168-6.811-4.948-4.823a.749.749 0 0 1 .416-1.279l6.838-.994L11.327.668a.75.75 0 0 1 1.345 0Z"
                      Fill="{StaticResource Decoration.Star}" Width="18" Height="18" Stretch="Uniform"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Path.RenderTransform>
                    <Path.Style>
                        <Style TargetType="Path">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1.2" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1.2" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1.0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource WarningTooltip}" Content="{loc:Translate Tooltip.LeaveStarOnGitHub}"
                             Placement="Left"/>
                </Button.ToolTip>
            </Button>
        </DockPanel>

        <!-- ── Scanning overlay ──────────────────────────────────── -->
        <Grid Grid.RowSpan="4" Visibility="{Binding Scan.IsScanning, Converter={StaticResource BoolToVis}}">
            <Rectangle Fill="{StaticResource Surface.Overlay}"/>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="8" Margin="{StaticResource GapBottom.Md}"
                             AutomationProperties.Name="{loc:Translate Automation.ScanningProgress}"/>
                <TextBlock Text="{Binding Scan.ScanProgress}" Foreground="{StaticResource Text.Heading}"
                           FontSize="{StaticResource Type.Heading.Sm}" HorizontalAlignment="Center" Margin="{StaticResource GapBottom.Lg}"/>
                <Button x:Name="ScanCancelButton" Style="{StaticResource GhostPill}"
                        Content="{loc:Translate Action.Cancel}" Command="{Binding Scan.CancelScanCommand}"
                        Height="28" Padding="16,0" FontSize="{StaticResource Type.Body}"
                        HorizontalAlignment="Center"
                        FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                        AutomationProperties.Name="{loc:Translate Automation.CancelScan}"/>
            </StackPanel>
        </Grid>

        <!-- ── Operating overlay ─────────────────────────────────── -->
        <Grid Grid.RowSpan="4" Visibility="{Binding Cleanup.IsOperating, Converter={StaticResource BoolToVis}}">
            <Rectangle Fill="{StaticResource Surface.Overlay}"/>
            <Border Background="{StaticResource Surface.Card}" CornerRadius="{StaticResource Radius.Pill}"
                    Padding="28,22" MinWidth="260"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding Cleanup.OperationProgress}" Foreground="{StaticResource Text.Heading}"
                               FontSize="{StaticResource Type.Heading.Sm}" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="{StaticResource GapBottom.Lg}"/>
                    <ProgressBar Value="{Binding Cleanup.OperationProgressPercent}"
                                 Minimum="0" Maximum="100"
                                 Width="200" Height="8" Margin="{StaticResource GapBottom.Sm}"
                                 AutomationProperties.Name="{loc:Translate Automation.OperationProgress}"/>
                    <DockPanel Margin="0,0,0,2">
                        <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}">
                            <Run Text="{Binding Cleanup.OperationProgressPercent, Mode=OneWay, StringFormat='{}{0:F0}%'}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Cleanup.OperationProgressDetail}"
                                   Foreground="{StaticResource Text.Dim}"
                                   FontSize="{StaticResource Type.Caption}"/>
                    </DockPanel>
                    <TextBlock Text="{Binding Cleanup.OperationCurrentFileName}"
                               Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis" MaxWidth="240"/>
                    <Button x:Name="OperationCancelButton" Style="{StaticResource GhostPill}" Content="{loc:Translate Action.Cancel}"
                            Command="{Binding Cleanup.CancelOperationCommand}"
                            AutomationProperties.Name="{loc:Translate Automation.CancelOperation}"
                            FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                            HorizontalAlignment="Center" Margin="0,8,0,0"
                            Height="28" Padding="16,0" FontSize="{StaticResource Type.Body}"/>
                </StackPanel>
            </Border>
        </Grid>
        <!-- ── Completion overlay ──────────────────────────────
             TabNavigation="Cycle" traps Tab inside the overlay.
             1px BorderBrush matches the confirm dialogs. -->
        <Grid x:Name="CompletionOverlay" Grid.RowSpan="4" Visibility="{Binding Completion.IsComplete, Converter={StaticResource BoolToVis}}"
              KeyboardNavigation.TabNavigation="Cycle"
              KeyboardNavigation.ControlTabNavigation="Cycle">
            <!-- Clicking the dim margin dismisses the overlay (the
                 inner Border absorbs its own clicks). -->
            <Rectangle Fill="{StaticResource Surface.Overlay}"
                       MouseLeftButtonDown="CompletionDimAreaClick"
                       Cursor="Arrow"/>
            <Border Background="{StaticResource Surface.Card}" CornerRadius="{StaticResource Radius.Pill}"
                    BorderBrush="{StaticResource Action.Primary.Background}" BorderThickness="1"
                    Padding="36,32" MinWidth="340" MaxWidth="420"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <!-- Icon -->
                    <Image Source="Assets/splash-icon.png"
                           Width="64" Height="64" HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="{StaticResource GapBottom.Lg}"/>

                    <!-- Heading -->
                    <TextBlock Text="{Binding Completion.Heading}"
                               Foreground="{StaticResource Status.Success}" FontSize="{StaticResource Type.Heading.Lg}" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="{StaticResource GapBottom.Sm}"/>

                    <!-- Summary -->
                    <TextBlock Text="{Binding Completion.Summary}"
                               Foreground="{StaticResource Text.Body}" FontSize="{StaticResource Type.Heading.Sm}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="0,0,0,6"/>

                    <!-- Restore guidance -->
                    <TextBlock Text="{Binding Completion.Restore}"
                               Foreground="{StaticResource Text.Muted}" FontSize="{StaticResource Type.Body}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="{StaticResource GapBottom.Xl}"/>

                    <!-- Error details (only visible when there are errors) -->
                    <Border Margin="{StaticResource GapBottom.Xl}" MaxHeight="80">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Completion.Errors}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <!-- IsTabStop=True overrides SelectableText so
                             a screen-reader user can Tab onto the
                             error list and scroll its overflow. -->
                        <TextBox Text="{Binding Completion.Errors, Mode=OneWay}"
                                 Style="{StaticResource SelectableText}"
                                 IsTabStop="True"
                                 Foreground="{StaticResource Status.Warning}" FontSize="{StaticResource Type.Caption}"
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                    </Border>

                    <!-- Closes this result screen, NOT the app: exiting
                         from here would trap the user with no way to
                         re-scan or open About. -->
                    <!-- The completion overlay auto-focuses this button so
                         Esc and Enter dismiss cleanly and screen readers
                         announce the action's result; FocusVisualStyle is
                         null because the focused-button ring around a
                         centred IsDefault button on a result screen reads
                         as a stuck "selected" state, especially after the
                         user Alt+Tabs away and back. Enter still activates
                         from anywhere via IsDefault, Esc dismisses through
                         OnPreviewKeyDown, Tab moves to "Scan again" which
                         carries its own focus ring as the visible target. -->
                    <Button x:Name="CompletionCloseButton" Style="{StaticResource AccentPill}"
                            Content="{loc:Translate Action.Close}" Command="{Binding Completion.DismissCommand}"
                            IsDefault="True" FocusVisualStyle="{x:Null}"
                            HorizontalAlignment="Center" MinWidth="120"
                            Margin="{StaticResource GapBottom.Sm}"
                            AutomationProperties.Name="{loc:Translate Automation.CloseResult}"/>

                    <!-- Scan again -->
                    <Button Style="{StaticResource GhostPill}"
                            Content="{loc:Translate Action.ScanAgain}" Command="{Binding Completion.RescanAfterCompletionCommand}"
                            HorizontalAlignment="Center"
                            Height="28" Padding="16,0" FontSize="{StaticResource Type.Body}"
                            FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                            AutomationProperties.Name="{loc:Translate Automation.RescanInstaller}"/>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
