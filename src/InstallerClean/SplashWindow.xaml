<Window x:Class="InstallerClean.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="InstallerClean"
        Width="480" Height="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="{StaticResource Base100}" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>     <!-- top spacer -->
                <RowDefinition Height="Auto"/>  <!-- icon -->
                <RowDefinition Height="16"/>    <!-- gap -->
                <RowDefinition Height="Auto"/>  <!-- app name -->
                <RowDefinition Height="28"/>    <!-- gap -->
                <RowDefinition Height="Auto"/>  <!-- progress bar -->
                <RowDefinition Height="8"/>     <!-- gap -->
                <RowDefinition Height="Auto"/>  <!-- step text -->
                <RowDefinition Height="12"/>    <!-- gap -->
                <RowDefinition Height="Auto"/>  <!-- cancel button -->
                <RowDefinition Height="*"/>     <!-- bottom spacer -->
            </Grid.RowDefinitions>

            <!-- Icon (centred hero) -->
            <Image Grid.Row="1" Source="Assets/splash-icon.png"
                   Width="96" Height="96"
                   HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- App name -->
            <TextBlock Grid.Row="3" Text="InstallerClean"
                       Foreground="{StaticResource Fg}"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <!-- Progress bar -->
            <Border Grid.Row="5" CornerRadius="12" Background="{StaticResource Base200}"
                    Height="20" Margin="48,0">
                <Border x:Name="SplashProgressBorder" CornerRadius="12"
                        HorizontalAlignment="Left" Width="0"
                        Background="{StaticResource Secondary}"/>
            </Border>
            <!-- Step text -->
            <TextBlock Grid.Row="7"
                       x:Name="StepText"
                       Text="Scanning..."
                       Foreground="{StaticResource Body}"
                       FontSize="12"
                       HorizontalAlignment="Center"/>

            <!-- Cancel button -->
            <Button Grid.Row="9"
                    x:Name="CancelButton"
                    Content="_Cancel"
                    Click="CancelClick"
                    IsCancel="True"
                    Style="{StaticResource GhostPill}"
                    Height="28" Padding="16,0" FontSize="12"
                    HorizontalAlignment="Center"
                    FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                    AutomationProperties.Name="Cancel startup scan"/>

            <!-- Version (bottom right, overlaid) -->
            <TextBlock Grid.Row="10"
                       x:Name="VersionText"
                       Foreground="{StaticResource Dim}"
                       FontSize="11"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,20,12"/>
        </Grid>
    </Border>
</Window>
