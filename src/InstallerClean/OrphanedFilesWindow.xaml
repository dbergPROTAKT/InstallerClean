<Window x:Class="InstallerClean.OrphanedFilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:InstallerClean.Resources"
        Title="{loc:Translate Window.Orphaned.Title}"
        Width="920" Height="540"
        MinWidth="600" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Surface.Sidebar}"
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" GlassFrameThickness="-1"
                      ResizeBorderThickness="4"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="{StaticResource DetailWindowMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="-8,-4,0,0">
            <Image Source="Assets/splash-icon.png" Width="16" Height="16"
                   RenderOptions.BitmapScalingMode="HighQuality" Margin="{StaticResource GapRight.Sm}"
                   AutomationProperties.Name=""/>
            <TextBlock Text="{loc:Translate Window.Orphaned.Title}" Foreground="{StaticResource Text.Body}"
                       FontSize="{StaticResource Type.Heading.Sm}" FontWeight="Medium"/>
        </StackPanel>
        <Button Grid.Row="0" Style="{StaticResource CaptionCloseButton}" Content="&#xE8BB;"
                Click="CloseClick" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="{StaticResource CloseButtonOverhangMargin}" AutomationProperties.Name="{loc:Translate Automation.CloseWindow}" ToolTip="{loc:Translate Tooltip.Close}"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardNoPad}">
                <ListBox x:Name="FilesList" ItemsSource="{Binding Files}"
                         SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         Margin="16,8,0,8" HorizontalContentAlignment="Stretch"
                         VirtualizingStackPanel.IsVirtualizing="True"
                         VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1,16,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="72"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding FileName}"
                                           Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Heading.Sm}"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding FullPath}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Reason}"
                                           Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}"
                                           Foreground="{StaticResource Text.Body}" FontSize="{StaticResource Type.Body}" TextAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <TextBlock Text="{loc:Translate Body.NoFileSelected}"
                               Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Body}" FontStyle="Italic"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               TextAlignment="Center" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="{loc:Translate Body.NoMetadata}"
                               Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Body}" FontStyle="Italic"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Visibility="{Binding ShowNoMetadata, Converter={StaticResource BoolToVis}}"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding ShowDetails, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Translate Field.Reason}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                            <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding SelectedFile.Reason, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Translate Field.Author}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                            <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding SelectedDetails.Author, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{loc:Translate Field.Application}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                            <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding SelectedDetails.AppName, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="{loc:Translate Field.Title}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                            <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding SelectedDetails.Title, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="{loc:Translate Field.Subject}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                            <TextBox Grid.Row="8" Grid.Column="2" Text="{Binding SelectedDetails.Subject, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="10" Grid.Column="0" Text="{loc:Translate Field.Keywords}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                            <TextBox Grid.Row="10" Grid.Column="2" Text="{Binding SelectedDetails.Keywords, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="12" Grid.Column="0" Text="{loc:Translate Field.SigningCertificate}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"
                                       ToolTip="{loc:Translate Tooltip.SigningCertificate}"/>
                            <TextBox Grid.Row="12" Grid.Column="2" Text="{Binding SelectedDetails.DigitalSignature, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="14" Grid.Column="0" Text="{loc:Translate Field.FileSize}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                            <TextBox Grid.Row="14" Grid.Column="2" Text="{Binding SelectedFile.SizeDisplay, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}"/>
                            <TextBlock Grid.Row="16" Grid.Column="0" Text="{loc:Translate Field.Comment}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                            <TextBox Grid.Row="16" Grid.Column="2" Text="{Binding SelectedDetails.Comments, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"/>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="3" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left" Text="{Binding Summary}"
                       Foreground="{StaticResource Text.Body}" FontSize="{StaticResource Type.Body}" VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryPill}"
                    Content="{loc:Translate Action.Close}" IsCancel="True"/>
        </DockPanel>
    </Grid>
</Window>
