<Window x:Class="InstallerClean.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        Width="500" Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource Base100}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" GlassFrameThickness="-1"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Grid Margin="{StaticResource DetailWindowMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="-8,0,0,0">
            <Image Source="Assets/splash-icon.png" Width="16" Height="16"
                   RenderOptions.BitmapScalingMode="HighQuality" Margin="{StaticResource GapRight.Sm}"/>
            <TextBlock Text="About" Foreground="{StaticResource Body}"
                       FontSize="14" FontWeight="Medium"/>
        </StackPanel>
        <Button Grid.Row="0" Style="{StaticResource CaptionCloseButton}" Content="&#x2715;"
                Click="CloseClick" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,-4,-24,0" AutomationProperties.Name="Close"/>

        <TextBlock Grid.Row="1" Text="InstallerClean"
                   Foreground="{StaticResource Fg}" FontSize="20" FontWeight="SemiBold"/>

        <TextBox Grid.Row="3" x:Name="VersionText"
                 Style="{StaticResource SelectableText}" Foreground="{StaticResource Body}" FontSize="12"
                 Margin="-2,0,0,0"/>

        <TextBlock Grid.Row="5" Foreground="{StaticResource Muted}" FontSize="12">
            <Hyperlink NavigateUri="https://github.com/no-faff/InstallerClean/blob/main/LICENSE"
                       Click="Hyperlink_Click"
                       Style="{StaticResource SubtleLink}">MIT licence</Hyperlink>
        </TextBlock>

        <DockPanel Grid.Row="7" LastChildFill="False">
            <Button DockPanel.Dock="Left" Style="{StaticResource CompactGhostPill}"
                    Click="StarClick" AutomationProperties.Name="Leave a star on GitHub"
                    Margin="-12,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <Path Data="m12.672.668 3.059 6.197 6.838.993a.75.75 0 0 1 .416 1.28l-4.948 4.823 1.168 6.812a.75.75 0 0 1-1.088.79L12 18.347l-6.116 3.216a.75.75 0 0 1-1.088-.791l1.168-6.811-4.948-4.823a.749.749 0 0 1 .416-1.279l6.838-.994L11.327.668a.75.75 0 0 1 1.345 0Z"
                          Fill="{StaticResource Warning}" Width="12" Height="12" Stretch="Uniform"
                          VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Star on GitHub" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button DockPanel.Dock="Left" Style="{StaticResource CompactGhostPill}"
                    Click="DonateClick" AutomationProperties.Name="Buy me a cuppa">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                          Fill="{StaticResource Heart}" Width="12" Height="12" Stretch="Uniform"
                          VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Donate" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button DockPanel.Dock="Right" Style="{StaticResource CompactPill}"
                    Content="_Close" IsCancel="True"/>
            <Button DockPanel.Dock="Right" Style="{StaticResource CompactPill}"
                    x:Name="CheckNowButton"
                    Content="_Check for updates" Click="CheckNowClick"
                    Margin="0,0,8,0"/>
        </DockPanel>
    </Grid>
</Window>
