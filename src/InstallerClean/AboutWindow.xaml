<Window x:Class="InstallerClean.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        Width="420" Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource Base100}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" GlassFrameThickness="-1"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="SubtleLink" TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="TextDecorations" Value="None"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="{StaticResource DetailWindowMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="-8,0,0,0">
            <Image Source="Assets/splash-icon.png" Width="16" Height="16"
                   RenderOptions.BitmapScalingMode="HighQuality" Margin="{StaticResource GapRight.Sm}"/>
            <TextBlock Text="About" Foreground="{StaticResource Body}"
                       FontSize="14" FontWeight="Medium"/>
        </StackPanel>
        <Button Grid.Row="0" Style="{StaticResource CaptionCloseButton}" Content="&#x2715;"
                Click="CloseClick" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,-4,-24,0" AutomationProperties.Name="Close"/>

        <TextBlock Grid.Row="1" Text="InstallerClean"
                   Foreground="{StaticResource Fg}" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap"/>
        <TextBox Grid.Row="3" x:Name="VersionText"
                 Style="{StaticResource SelectableText}" Foreground="{StaticResource Body}" FontSize="12"/>
        <TextBlock Grid.Row="5" Foreground="{StaticResource Muted}" FontSize="12">
            <Hyperlink NavigateUri="https://github.com/no-faff/InstallerClean/blob/main/LICENSE"
                       Click="Hyperlink_Click"
                       Style="{StaticResource SubtleLink}">MIT licence</Hyperlink>
        </TextBlock>
        <TextBlock Grid.Row="7" Foreground="{StaticResource Muted}" FontSize="12">
            <Hyperlink NavigateUri="https://github.com/no-faff"
                       Click="Hyperlink_Click"
                       Style="{StaticResource SubtleLink}">github.com/no-faff</Hyperlink>
        </TextBlock>
        <!-- Update check. Negative left margin cancels the pill's 12px left
             padding so the text aligns with the plain TextBlocks above it;
             the hover background still extends to the pill's full width. -->
        <Button x:Name="CheckNowButton" Grid.Row="9"
                Style="{StaticResource GhostPill}"
                Content="_Check for updates" Click="CheckNowClick"
                Height="28" Padding="12,0" FontSize="12"
                HorizontalAlignment="Left" Margin="-12,0,0,0"/>

        <Button Grid.Row="11" Style="{StaticResource PrimaryPill}"
                Content="_Close" IsCancel="True" HorizontalAlignment="Right"/>
        <TextBlock Grid.Row="11" HorizontalAlignment="Left"
                   VerticalAlignment="Center" Foreground="{StaticResource Muted}" FontSize="12">
            <Hyperlink NavigateUri="https://github.com/no-faff/InstallerClean/discussions"
                       Click="Hyperlink_Click"
                       Style="{StaticResource SubtleLink}">Send feedback</Hyperlink>
        </TextBlock>
    </Grid>
</Window>
