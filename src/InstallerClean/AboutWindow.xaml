<Window x:Class="InstallerClean.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:InstallerClean.Resources"
        Title="{loc:Translate Window.About.Title}"
        Width="500" Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource Surface.Sidebar}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" GlassFrameThickness="-1"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Grid Margin="{StaticResource DetailWindowMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="-8,-4,0,0">
            <Image Source="Assets/splash-icon.png" Width="16" Height="16"
                   RenderOptions.BitmapScalingMode="HighQuality" Margin="{StaticResource GapRight.Sm}"/>
            <TextBlock Text="{loc:Translate Window.About.Title}" Foreground="{StaticResource Text.Body}"
                       FontSize="{StaticResource Type.Heading.Sm}" FontWeight="Medium"/>
        </StackPanel>
        <Button Grid.Row="0" Style="{StaticResource CaptionCloseButton}" Content="&#xE8BB;" ToolTip="{loc:Translate Tooltip.Close}"
                Click="CloseClick" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,-4,-24,0" AutomationProperties.Name="{loc:Translate Automation.Close}"/>

        <TextBlock Grid.Row="1" Text="{loc:Translate Window.Main.Title}"
                   Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Heading.Md}" FontWeight="SemiBold"/>

        <!-- The status TextBlock to the right of the version is the
             result channel for the Check-for-updates button below.
             LiveSetting=Polite so the in-flight wait is announced to
             Narrator / NVDA / JAWS; without it the button click reads
             as silent. -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="VersionText"
                     Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Body}" FontSize="{StaticResource Type.Body}"
                     VerticalAlignment="Center" Margin="-2,0,0,0"/>
            <TextBlock Grid.Column="2" x:Name="CheckStatusText"
                       Foreground="{StaticResource Text.Muted}" FontSize="{StaticResource Type.Body}"
                       VerticalAlignment="Center" TextWrapping="NoWrap"
                       AutomationProperties.LiveSetting="Polite"/>
        </Grid>

        <TextBlock Grid.Row="5" Foreground="{StaticResource Text.Muted}" FontSize="{StaticResource Type.Body}">
            <Hyperlink NavigateUri="https://github.com/no-faff/InstallerClean/blob/main/LICENSE"
                       Click="Hyperlink_Click"
                       Style="{StaticResource SubtleLink}"><Run Text="{loc:Translate Action.MITLicence}"/></Hyperlink>
        </TextBlock>

        <Button Grid.Row="7" Style="{StaticResource CompactPill}"
                x:Name="CheckNowButton"
                Content="{loc:Translate Action.CheckForUpdates}" Click="CheckNowClick"
                HorizontalAlignment="Left"/>

        <!-- Quiet section header above the Star + Donate row. The resx
             value is already uppercased so screen readers don't see
             SmallCaps glyph mapping at all. -->
        <TextBlock Grid.Row="9" Text="{loc:Translate Section.SayThanks}"
                   Foreground="{StaticResource Text.Muted}" FontSize="{StaticResource Type.Body}"
                   FontWeight="Medium"
                   AutomationProperties.Name="{loc:Translate Automation.SayThanks}"/>

        <Grid Grid.Row="11">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Style="{StaticResource CompactGhostPill}"
                        Click="StarClick" AutomationProperties.Name="{loc:Translate Automation.LeaveStarOnGitHub}"
                        ToolTip="{loc:Translate Tooltip.OpenProjectOnGitHub}"
                        Margin="-12,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="m12.672.668 3.059 6.197 6.838.993a.75.75 0 0 1 .416 1.28l-4.948 4.823 1.168 6.812a.75.75 0 0 1-1.088.79L12 18.347l-6.116 3.216a.75.75 0 0 1-1.088-.791l1.168-6.811-4.948-4.823a.749.749 0 0 1 .416-1.279l6.838-.994L11.327.668a.75.75 0 0 1 1.345 0Z"
                              Fill="{StaticResource Decoration.Star}" Width="12" Height="12" Stretch="Uniform"
                              VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <AccessText Text="{loc:Translate Action.LeaveStarOnGitHub}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource CompactGhostPill}"
                        Click="DonateClick" AutomationProperties.Name="{loc:Translate Automation.BuyMeACuppa}"
                        ToolTip="{loc:Translate Tooltip.Donate}"
                        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                              Fill="{StaticResource Decoration.Heart}" Width="12" Height="12" Stretch="Uniform"
                              VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <AccessText Text="{loc:Translate Action.BuyMeACuppa}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <Button Style="{StaticResource CompactPill}"
                    Content="{loc:Translate Action.Close}" IsCancel="True"
                    HorizontalAlignment="Right"
                    AutomationProperties.Name="{loc:Translate Automation.Close}"/>
        </Grid>
    </Grid>
</Window>
