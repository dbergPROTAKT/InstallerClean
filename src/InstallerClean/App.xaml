<Application x:Class="InstallerClean.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- ============================================================
                 Spacing scale
                 Use Space.* as bare doubles (widths, heights, paddings that
                 need a scalar). Use Gap.* as Thicknesses when you need a
                 Margin or Padding resource. Gap.*.Bottom / GapRight etc.
                 provide directional shapes for common one-sided spacing.
                 ============================================================ -->
            <sys:Double x:Key="Space.Xs">4</sys:Double>
            <sys:Double x:Key="Space.Sm">8</sys:Double>
            <sys:Double x:Key="Space.Md">12</sys:Double>
            <sys:Double x:Key="Space.Lg">16</sys:Double>
            <sys:Double x:Key="Space.Xl">24</sys:Double>
            <sys:Double x:Key="Space.Xxl">32</sys:Double>

            <Thickness x:Key="Gap.Sm">8</Thickness>
            <Thickness x:Key="Gap.Md">12</Thickness>
            <Thickness x:Key="Gap.Lg">16</Thickness>
            <Thickness x:Key="Gap.Xl">24</Thickness>

            <Thickness x:Key="GapBottom.Sm">0,0,0,8</Thickness>
            <Thickness x:Key="GapBottom.Md">0,0,0,12</Thickness>
            <Thickness x:Key="GapBottom.Lg">0,0,0,16</Thickness>
            <Thickness x:Key="GapBottom.Xl">0,0,0,24</Thickness>

            <Thickness x:Key="GapRight.Sm">0,0,8,0</Thickness>
            <Thickness x:Key="GapRight.Md">0,0,12,0</Thickness>

            <Thickness x:Key="GapLeft.Md">12,0,0,0</Thickness>

            <!-- Outer margin shared by the detail windows (Orphaned,
                 Registered, About) so they share a consistent inset. -->
            <Thickness x:Key="DetailWindowMargin">24,4,24,24</Thickness>

            <!-- Poppins font (bundled locally, matching Upscayl) -->
            <FontFamily x:Key="Poppins">pack://application:,,,/Fonts/#Poppins</FontFamily>
            <Style TargetType="Window">
                <Setter Property="FontFamily" Value="{StaticResource Poppins}"/>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource Poppins}"/>
            </Style>

            <!-- Read-only TextBox that looks like a TextBlock but is selectable -->
            <Style x:Key="SelectableText" TargetType="TextBox">
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="FontFamily" Value="{StaticResource Poppins}"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="ContextMenu">
                    <Setter.Value>
                        <ContextMenu>
                            <MenuItem Header="Copy" Command="ApplicationCommands.Copy"/>
                        </ContextMenu>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Upscayl palette (from tailwind.config.js daisyui theme) -->
            <SolidColorBrush x:Key="Base300" Color="#020617"/>   <!-- deepest background -->
            <SolidColorBrush x:Key="Base200" Color="#0f172a"/>   <!-- card / elevated surface -->
            <SolidColorBrush x:Key="Base100" Color="#1e293b"/>   <!-- sidebar-level surface -->
            <SolidColorBrush x:Key="Primary" Color="#334155"/>   <!-- standard button fill -->
            <SolidColorBrush x:Key="Secondary" Color="#4f46e5"/> <!-- CTA / accent button -->
            <SolidColorBrush x:Key="Accent" Color="#6d28d9"/>    <!-- selection highlight -->
            <SolidColorBrush x:Key="Neutral" Color="#475569"/>   <!-- badges, neutral -->
            <SolidColorBrush x:Key="Danger" Color="#991b1b"/>    <!-- destructive -->
            <SolidColorBrush x:Key="Fg" Color="#f8fafc"/>        <!-- foreground text -->
            <SolidColorBrush x:Key="Body" Color="#cbd5e1"/>      <!-- body text (80% base-content) -->
            <SolidColorBrush x:Key="Muted" Color="#94a3b8"/>     <!-- muted text (50% base-content) -->
            <SolidColorBrush x:Key="Dim" Color="#8494a7"/>        <!-- dim text (metadata labels, placeholders) -->
            <SolidColorBrush x:Key="Warning" Color="#f59e0b"/>    <!-- warning / caution -->
            <SolidColorBrush x:Key="Success" Color="#4ade80"/>   <!-- completion / positive outcome -->
            <SolidColorBrush x:Key="Heart"   Color="#ef4444"/>   <!-- donate heart icon -->
            <SolidColorBrush x:Key="Overlay" Color="#80020617"/> <!-- 50% base-300 overlay -->

            <!-- Interactive-state brushes derived from the base palette -->
            <SolidColorBrush x:Key="SecondaryHover"      Color="#443cc7"/>
            <SolidColorBrush x:Key="SecondaryPressed"    Color="#3b34af"/>
            <SolidColorBrush x:Key="PrimaryHover"        Color="#2b3749"/>
            <SolidColorBrush x:Key="PrimaryPressed"      Color="#232e3d"/>
            <SolidColorBrush x:Key="CaptionCloseHover"   Color="#c0392b"/>
            <SolidColorBrush x:Key="CaptionClosePressed" Color="#a93226"/>
            <SolidColorBrush x:Key="Thumb"               Color="#33f8fafc"/>
            <SolidColorBrush x:Key="ThumbHover"          Color="#80f8fafc"/>
            <SolidColorBrush x:Key="Link"                Color="#818cf8"/>

            <!-- Card style: rounded like Upscayl, no shadows, just tone shift -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource Base200}"/>
                <Setter Property="CornerRadius" Value="20"/>
                <Setter Property="Padding" Value="16"/>
            </Style>

            <Style x:Key="CardNoPad" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource Base200}"/>
                <Setter Property="CornerRadius" Value="20"/>
            </Style>

            <!-- Focus visual for pill controls (40px tall, 20px inner radius).
                 Drawn 2px outside the control bounds in Body slate so keyboard
                 focus stays visible regardless of the button's own colour
                 (handles the indigo-on-indigo case for AccentPill, and the
                 indigo-on-red case for the bespoke Delete button). -->
            <Style x:Key="PillFocusVisual">
                <Setter Property="Control.Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <Border CornerRadius="22"
                                    BorderThickness="2"
                                    BorderBrush="{DynamicResource Body}"
                                    Margin="-2"
                                    SnapsToDevicePixels="True"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Focus visual for compact pill buttons (30px tall, 15px inner radius). -->
            <Style x:Key="CompactPillFocusVisual">
                <Setter Property="Control.Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <Border CornerRadius="17"
                                    BorderThickness="2"
                                    BorderBrush="{DynamicResource Body}"
                                    Margin="-2"
                                    SnapsToDevicePixels="True"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Focus visual for small pill buttons (28px tall: heart, star,
                 cancel-overlay buttons, scan-again, splash cancel).
                 Explicit CornerRadius=16 sized for the smaller bounds so the
                 ring renders correctly without relying on WPF auto-clamp. -->
            <Style x:Key="SmallPillFocusVisual">
                <Setter Property="Control.Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <Border CornerRadius="16"
                                    BorderThickness="2"
                                    BorderBrush="{DynamicResource Body}"
                                    Margin="-2"
                                    SnapsToDevicePixels="True"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Pill buttons: rounded-btn 2rem (32px), h-10 (40px) -->

            <!-- CTA / accent pill (Move, Save) /indigo #4f46e5 -->
            <Style x:Key="AccentPill" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Padding" Value="28,8"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="MinWidth" Value="120"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource PillFocusVisual}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{StaticResource Secondary}" CornerRadius="20"
                                    Padding="{TemplateBinding Padding}"
                                    Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource SecondaryHover}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource SecondaryHover}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource SecondaryPressed}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Primary pill (Browse, Add, Close) /slate #334155 -->
            <Style x:Key="PrimaryPill" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Padding" Value="28,8"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="MinWidth" Value="120"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource PillFocusVisual}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{StaticResource Primary}" CornerRadius="20"
                                    Padding="{TemplateBinding Padding}"
                                    Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource PrimaryHover}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource PrimaryHover}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource PrimaryPressed}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Ghost pill (Settings, Refresh, About) /transparent, muted text -->
            <Style x:Key="GhostPill" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Padding" Value="20,8"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource PillFocusVisual}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="20"
                                    Padding="{TemplateBinding Padding}"
                                    Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Body}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CompactPill" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Padding" Value="14,0"/>
                <Setter Property="Height" Value="30"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource CompactPillFocusVisual}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{StaticResource Primary}" CornerRadius="15"
                                    Padding="{TemplateBinding Padding}"
                                    Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource PrimaryHover}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource PrimaryHover}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource PrimaryPressed}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CompactGhostPill" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="Height" Value="30"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource CompactPillFocusVisual}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="15"
                                    Padding="{TemplateBinding Padding}"
                                    Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Body}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Pill TextBox /rounded input matching Upscayl's input style -->
            <Style x:Key="PillTextBox" TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource Base200}"/>
                <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                <Setter Property="CaretBrush" Value="{StaticResource Fg}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource PillFocusVisual}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                    CornerRadius="20">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- Dark selection for ListView items (overrides wpfui white/blue highlight) -->
            <Style TargetType="ListViewItem">
                <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Border x:Name="Bd" Background="Transparent" Padding="4,6">
                                <GridViewRowPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Primary}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Base100}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Dark selection for ListBox items (overrides wpfui white/blue highlight) -->
            <Style TargetType="ListBoxItem">
                <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd" Background="Transparent" Padding="2,2">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Primary}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Base100}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Dark GridViewColumnHeader (overrides wpfui white header) -->
            <Style TargetType="GridViewColumnHeader">
                <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GridViewColumnHeader">
                            <Border Background="Transparent" Padding="8,6" BorderThickness="0,0,0,1"
                                    BorderBrush="{StaticResource Base100}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Link button (details..., text-only, coloured like a hyperlink) -->
            <Style x:Key="LinkButton" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource Link}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="Tx" Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       VerticalAlignment="Center"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Tx" Property="TextDecorations" Value="Underline"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Tx" Property="TextDecorations" Value="Underline"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Tx" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SubtleLink" TargetType="Hyperlink">
                <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                <Setter Property="TextDecorations" Value="None"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Upscayl-style thin scrollbar: 8px, rounded, subtle thumb -->
            <Style x:Key="ThinThumb" TargetType="Thumb">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border x:Name="Bg" Background="{StaticResource Thumb}" CornerRadius="4"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource ThumbHover}"/>
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource ThumbHover}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Width" Value="8"/>
                <Setter Property="MinWidth" Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Border Background="Transparent" CornerRadius="4" Padding="0">
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ThinThumb}"/>
                                    </Track.Thumb>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="Orientation" Value="Horizontal">
                        <Setter Property="Width" Value="Auto"/>
                        <Setter Property="Height" Value="8"/>
                        <Setter Property="MinHeight" Value="8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Border Background="Transparent" CornerRadius="4" Padding="0">
                                        <Track x:Name="PART_Track">
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource ThinThumb}"/>
                                            </Track.Thumb>
                                        </Track>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Caption button (title bar minimise) -->
            <Style x:Key="CaptionButton" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Width" Value="46"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource Primary}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource Neutral}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource Primary}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Caption close button (red on hover) -->
            <Style x:Key="CaptionCloseButton" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Width" Value="46"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource CaptionCloseHover}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource CaptionClosePressed}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource CaptionCloseHover}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Tooltip (Upscayl-style: indigo bg, slight rounding) -->
            <Style x:Key="WarningTooltip" TargetType="ToolTip">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="MaxWidth" Value="280"/>
                <Setter Property="Placement" Value="Top"/>
                <Setter Property="HasDropShadow" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToolTip">
                            <Border Background="{StaticResource Secondary}" CornerRadius="4"
                                    Padding="10,6">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{StaticResource Fg}" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
