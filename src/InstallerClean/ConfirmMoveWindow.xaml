<Window x:Class="InstallerClean.ConfirmMoveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:InstallerClean.Resources"
        Title="{loc:Translate Window.ConfirmMove.Title}"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <!-- CaptionHeight=0: this is a centred-on-owner modal with no
             title-bar buttons, so no drag region is needed and the
             Border below claims the full window. -->
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource Surface.Card}" CornerRadius="{StaticResource Radius.Card}" Padding="32,28"
            MaxWidth="440" MinWidth="320"
            BorderBrush="{StaticResource Action.Primary.Background}" BorderThickness="1">
        <StackPanel>
            <TextBlock x:Name="MessageText" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Heading.Sm}"
                       TextWrapping="Wrap" Margin="{StaticResource GapBottom.Sm}"/>

            <TextBlock x:Name="DestinationText" Foreground="{StaticResource Text.Muted}" FontSize="{StaticResource Type.Body}"
                       TextWrapping="Wrap" Margin="{StaticResource GapBottom.Lg}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Cancel is the default for symmetry with the Confirm
                     Delete dialog: a reflexive Enter dismisses, never
                     commits. -->
                <Button Style="{StaticResource GhostPill}" Content="{loc:Translate Action.Cancel}"
                        Click="OnCancel" IsCancel="True" IsDefault="True"
                        Margin="{StaticResource GapRight.Sm}"/>
                <Button Style="{StaticResource AccentPill}" Content="{loc:Translate Action.Move}"
                        Click="OnMove"
                        AutomationProperties.Name="{loc:Translate Automation.ConfirmMove}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
