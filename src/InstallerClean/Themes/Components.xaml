<!--
    Component styles. Each Style here describes a control role
    (PrimaryPill, GhostPill, Card, etc) and consumes only semantic
    tokens from Tokens.xaml.

    Rule: nothing in this file references a Primitive.* key. If a
    component needs a colour or numeric that does not yet have a
    token, add it to Tokens.xaml first, then consume it here.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:loc="clr-namespace:InstallerClean.Resources">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Tokens.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ============================================================
         GLOBAL DEFAULTS
         Apply the bundled font to every Window and TextBlock so we
         never have to repeat FontFamily on individual controls.
         ============================================================ -->
    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="{StaticResource Type.FontFamily}"/>
    </Style>
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Type.FontFamily}"/>
    </Style>

    <!-- ============================================================
         SELECTABLE TEXT
         A read-only TextBox styled to look like a TextBlock but with
         user-selectable contents. Useful for showing values the user
         might want to copy (file paths, version strings, hashes).
         ============================================================ -->
    <Style x:Key="SelectableText" TargetType="TextBox">
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontFamily" Value="{StaticResource Type.FontFamily}"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu>
                    <MenuItem Header="{loc:Translate Action.Copy}" Command="ApplicationCommands.Copy"/>
                </ContextMenu>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         CARDS
         Rounded surface containers. Card has standard inner padding;
         CardNoPad lets the consumer control its own padding (used for
         lists that paint their own row spacing).
         ============================================================ -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface.Card}"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Pill}"/>
        <Setter Property="Padding" Value="{StaticResource Gap.Lg}"/>
    </Style>

    <Style x:Key="CardNoPad" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface.Card}"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Pill}"/>
    </Style>

    <!-- ============================================================
         FOCUS VISUALS
         Three sizes match the three pill heights (40 / 30 / 28).
         The default focus visual at the bottom of this file applies
         to anything else that takes focus (LinkButton, Hyperlink,
         plain Button) so keyboard navigation stays visible everywhere.
         ============================================================ -->
    <Style x:Key="PillFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border CornerRadius="{StaticResource Radius.PillFocus}"
                            BorderThickness="{StaticResource BorderThickness.Standard}"
                            BorderBrush="{DynamicResource Text.Body}"
                            Margin="-2"
                            SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CompactPillFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border CornerRadius="{StaticResource Radius.CompactPillFocus}"
                            BorderThickness="{StaticResource BorderThickness.Standard}"
                            BorderBrush="{DynamicResource Text.Body}"
                            Margin="-2"
                            SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SmallPillFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border CornerRadius="{StaticResource Radius.Card}"
                            BorderThickness="{StaticResource BorderThickness.Standard}"
                            BorderBrush="{DynamicResource Text.Body}"
                            Margin="-2"
                            SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         PILL BUTTONS
         Four flavours sharing one visual language (40px tall, fully
         rounded, 14pt Medium label):
           AccentPill  - secondary action colour (CTA / Move).
           PrimaryPill - primary action colour (Browse / Add / Close).
           DangerPill  - destructive action colour (Delete).
           GhostPill   - text-only action with no fill (Settings / About).
         ============================================================ -->

    <Style x:Key="AccentPill" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="FontSize" Value="{StaticResource Type.Heading.Sm}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="28,8"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource PillFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{StaticResource Action.Secondary.Background}"
                            CornerRadius="{StaticResource Radius.Pill}"
                            Padding="{TemplateBinding Padding}"
                            Height="{TemplateBinding Height}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Secondary.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Secondary.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Secondary.Pressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryPill" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="FontSize" Value="{StaticResource Type.Heading.Sm}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="28,8"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource PillFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{StaticResource Action.Primary.Background}"
                            CornerRadius="{StaticResource Radius.Pill}"
                            Padding="{TemplateBinding Padding}"
                            Height="{TemplateBinding Height}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Pressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DangerPill" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="FontSize" Value="{StaticResource Type.Heading.Sm}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="28,8"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource PillFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{StaticResource Action.Danger.Background}"
                            CornerRadius="{StaticResource Radius.Pill}"
                            Padding="{TemplateBinding Padding}"
                            Height="{TemplateBinding Height}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Danger.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Danger.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Danger.Pressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GhostPill" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Muted}"/>
        <Setter Property="FontSize" Value="{StaticResource Type.Heading.Sm}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="20,8"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource PillFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent"
                            CornerRadius="{StaticResource Radius.Pill}"
                            Padding="{TemplateBinding Padding}"
                            Height="{TemplateBinding Height}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Text.Body}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         COMPACT PILL BUTTONS (30px tall)
         Compact variants for the About dialog action row.
         ============================================================ -->

    <Style x:Key="CompactPill" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="FontSize" Value="{StaticResource Type.Body}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource CompactPillFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{StaticResource Action.Primary.Background}"
                            CornerRadius="15"
                            Padding="{TemplateBinding Padding}"
                            Height="{TemplateBinding Height}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Pressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CompactGhostPill" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Muted}"/>
        <Setter Property="FontSize" Value="{StaticResource Type.Body}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource CompactPillFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent"
                            CornerRadius="15"
                            Padding="{TemplateBinding Padding}"
                            Height="{TemplateBinding Height}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Text.Body}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         INPUTS
         ============================================================ -->

    <Style x:Key="PillTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Surface.Card}"/>
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Text.Heading}"/>
        <Setter Property="FontSize" Value="{StaticResource Type.Heading.Sm}"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource PillFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.Pill}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         LIST ITEMS
         ListView and ListBox row styles. Selection highlight uses the
         primary action background (not the violet selection accent),
         to read as "this row is the active selection" rather than
         "this row is brand-flavoured".
         ============================================================ -->

    <Style TargetType="ListViewItem">
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="Bd" Background="Transparent" Padding="4,6">
                        <GridViewRowPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Action.Primary.Background}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface.Sidebar}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="Transparent" Padding="2,2">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Action.Primary.Background}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface.Sidebar}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="GridViewColumnHeader">
        <Setter Property="Foreground" Value="{StaticResource Text.Muted}"/>
        <Setter Property="FontSize" Value="{StaticResource Type.Caption}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewColumnHeader">
                    <Border Background="Transparent" Padding="8,6"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{StaticResource Surface.Sidebar}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         LINKS
         LinkButton: stand-alone link control (e.g. "Details..." actions).
         SubtleLink: in-body Hyperlink that brightens to full Link
         colour on hover so it doesn't shout when sat in a paragraph.
         ============================================================ -->

    <Style x:Key="LinkButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Link.Default}"/>
        <Setter Property="FontSize" Value="{StaticResource Type.Heading.Sm}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <TextBlock x:Name="Tx" Text="{TemplateBinding Content}"
                               Foreground="{TemplateBinding Foreground}"
                               FontSize="{TemplateBinding FontSize}"
                               VerticalAlignment="Center"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Tx" Property="TextDecorations" Value="Underline"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Tx" Property="TextDecorations" Value="Underline"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Tx" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SubtleLink" TargetType="Hyperlink">
        <Setter Property="Foreground" Value="{StaticResource Link.Inline}"/>
        <Setter Property="TextDecorations" Value="None"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <!-- Underline AND brighten on hover so the link is
                 discoverable. Without an underline change, hover-only
                 reveals the link by colour shift, which fails for users
                 with reduced colour vision. -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource Link.Default}"/>
                <Setter Property="TextDecorations" Value="Underline"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================
         SCROLLBAR
         Thin (8px), rounded, subtle thumb that brightens on hover.
         Both horizontal and vertical orientations covered through one
         keyed Thumb style and a Style.Triggers branch.
         ============================================================ -->

    <Style x:Key="ThinThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Bg" Background="{StaticResource Scrollbar.Thumb}"
                            CornerRadius="{StaticResource Radius.Chip}"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Scrollbar.Thumb.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Scrollbar.Thumb.Hover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="8"/>
        <Setter Property="MinWidth" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Border Background="Transparent"
                            CornerRadius="{StaticResource Radius.Chip}"
                            Padding="0">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ThinThumb}"/>
                            </Track.Thumb>
                        </Track>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="8"/>
                <Setter Property="MinHeight" Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Border Background="Transparent"
                                    CornerRadius="{StaticResource Radius.Chip}"
                                    Padding="0">
                                <Track x:Name="PART_Track">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ThinThumb}"/>
                                    </Track.Thumb>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================
         CAPTION BUTTONS
         Title-bar minimise / maximise / close. Distinct CaptionClose
         style because the close button uses Action.CaptionClose.* on
         hover (red, matching the Windows convention) where the others
         use the standard Action.Primary background.
         ============================================================ -->

    <Style x:Key="CaptionButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Muted}"/>
        <!-- 13 is a deliberate off-scale glyph size: the title-bar
             characters (- HORIZONTAL BAR / WHITE SQUARE / MULTIPLICATION
             SIGN) read crowded at 14 (Type.Heading.Sm) and pinched at
             12 (Type.Body). Used only by the two caption styles below;
             not promoted to a Type.* token because no other control
             needs this size. -->
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Background}"/>
                            <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Neutral}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Background}"/>
                            <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CaptionCloseButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Muted}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.CaptionClose.Hover}"/>
                            <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.CaptionClose.Pressed}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.CaptionClose.Hover}"/>
                            <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         TOOLTIPS
         WarningTooltip: indigo accent tooltip for the donate / star
         buttons that shouts a little. The implicit ToolTip style
         below is the default for everything else.
         ============================================================ -->

    <Style x:Key="WarningTooltip" TargetType="ToolTip">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="MaxWidth" Value="280"/>
        <Setter Property="Placement" Value="Top"/>
        <Setter Property="HasDropShadow" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{StaticResource Action.Secondary.Background}"
                            CornerRadius="{StaticResource Radius.Chip}"
                            Padding="10,6">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{StaticResource Text.Heading}"
                                   FontSize="{StaticResource Type.Body}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Default ToolTip for attribute-syntax ToolTip="..." usages. Dark
         card surface, hairline border, body text. -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HasDropShadow" Value="False"/>
        <Setter Property="MaxWidth" Value="320"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{StaticResource Surface.Sidebar}"
                            BorderBrush="{StaticResource Action.Primary.Background}"
                            BorderThickness="{StaticResource BorderThickness.Hairline}"
                            CornerRadius="{StaticResource Radius.Chip}"
                            Padding="10,6">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{StaticResource Text.Body}"
                                   FontSize="{StaticResource Type.Body}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         DEFAULT FOCUS VISUAL
         Catches anything that takes focus but has no FocusVisualStyle
         override (plain Buttons, LinkButtons, Hyperlinks). Pill
         buttons opt out via their own *FocusVisual styles above.
         ============================================================ -->
    <Style x:Key="{x:Static SystemParameters.FocusVisualStyleKey}">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle RadiusX="2" RadiusY="2"
                               Stroke="{DynamicResource Text.Body}"
                               StrokeThickness="{StaticResource Border.Hairline}"
                               SnapsToDevicePixels="True"
                               Margin="-1"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         PROGRESS BAR
         Slim dark bar. Determinate uses PART_Indicator (WPF stock).
         Indeterminate moves the RepeatBehavior onto the DoubleAnimation
         rather than the wrapping Storyboard so the compiled BAML
         doesn't carry the literal "Storyboard RepeatBehavior=Forever"
         attribute pair.

         The indeterminate animation translates the 80px bar from
         X=-80 to X=320 (max bar width 240px). DoubleAnimation can't
         template-bind ActualWidth; raise the To value if a wider
         indeterminate consumer appears.
         ============================================================ -->
    <Style TargetType="ProgressBar">
        <Setter Property="Background" Value="{StaticResource Surface.Sidebar}"/>
        <Setter Property="Foreground" Value="{StaticResource Action.Secondary.Background}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border CornerRadius="{StaticResource Radius.Chip}"
                            Background="{TemplateBinding Background}"
                            ClipToBounds="True">
                        <Grid>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator"
                                    CornerRadius="{StaticResource Radius.Chip}"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"/>
                            <Border x:Name="IndeterminateBar"
                                    Width="80"
                                    CornerRadius="{StaticResource Radius.Chip}"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    Visibility="Collapsed"
                                    RenderTransformOrigin="0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="IndeterminateTransform"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsIndeterminate" Value="True">
                            <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="IndeterminateBar" Property="Visibility" Value="Visible"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndeterminateTransform"
                                                         Storyboard.TargetProperty="X"
                                                         From="-80" To="320"
                                                         Duration="0:0:1.4"
                                                         RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         CONTEXT MENU & MENU ITEM
         Padding/CornerRadius literals here are per-control tunings,
         not spacing-token decisions: the Spacing scale is uniform and
         doesn't represent the asymmetric (12,6) padding menu rows want.
         ============================================================ -->

    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource Surface.Sidebar}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Action.Primary.Background}"/>
        <Setter Property="BorderThickness" Value="{StaticResource BorderThickness.Hairline}"/>
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="HasDropShadow" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Chip}"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel IsItemsHost="True"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Text.Body}"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="{StaticResource Radius.Tight}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                              VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{TemplateBinding InputGestureText}"
                                       Margin="20,0,0,0"
                                       Foreground="{StaticResource Text.Dim}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Background}"/>
                            <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource Text.Dim}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
