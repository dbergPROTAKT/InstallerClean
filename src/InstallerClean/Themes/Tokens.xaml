<!--
    Semantic design tokens. Each entry is a role in the UI vocabulary.

    Colour roles resolve to a Color in Primitives.xaml. Numeric roles
    (typography, radius, border, spacing) carry a literal value plus a
    comment naming the corresponding step in the primitive scale so
    the canonical scale stays legible.

    Window XAML and component styles consume tokens from this file,
    never primitives. A colour or scale change edits the token here,
    not the consumer. A new role with no existing token gets a new
    token rather than a direct primitive reach.

    Naming: <category>.<role>[.<state>].
        Surface.*, Text.*, Action.<intent>.<state>, Status.*,
        Decoration.*, Link.*, Selection.*, Scrollbar.*, Type.*,
        Radius.*, Border.*, BorderThickness.*, Gap.*, GapBottom.*,
        GapRight.*, GapLeft.*, GapX.*.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Primitives.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Surfaces. The three layered backgrounds (window, sidebar-
         level, card) plus the modal overlay tint. -->
    <SolidColorBrush x:Key="Surface.AppBackground" Color="{StaticResource Primitive.Slate.950}"/>
    <SolidColorBrush x:Key="Surface.Sidebar"       Color="{StaticResource Primitive.Slate.800}"/>
    <SolidColorBrush x:Key="Surface.Card"          Color="{StaticResource Primitive.Slate.900}"/>
    <SolidColorBrush x:Key="Surface.Overlay"       Color="{StaticResource Primitive.Slate.950.Alpha50}"/>

    <!-- Text tiers. Heading > Body > Muted > Dim. The lowest tier
         that still reads at the rendered size wins. -->
    <SolidColorBrush x:Key="Text.Heading" Color="{StaticResource Primitive.Slate.50}"/>
    <SolidColorBrush x:Key="Text.Body"    Color="{StaticResource Primitive.Slate.300}"/>
    <SolidColorBrush x:Key="Text.Muted"   Color="{StaticResource Primitive.Slate.400}"/>
    <SolidColorBrush x:Key="Text.Dim"     Color="{StaticResource Primitive.Slate.500}"/>

    <!-- Actions. Each action role has Default / Hover / Pressed
         states. Buttons consume these via component styles in
         Components.xaml; raw window XAML reaches for them only for
         one-offs (e.g. Selection.Background on a list item). -->

    <!-- Primary: standard button (slate). -->
    <SolidColorBrush x:Key="Action.Primary.Background" Color="{StaticResource Primitive.Slate.700}"/>
    <SolidColorBrush x:Key="Action.Primary.Hover"      Color="{StaticResource Primitive.Slate.700.Hover}"/>
    <SolidColorBrush x:Key="Action.Primary.Pressed"    Color="{StaticResource Primitive.Slate.700.Pressed}"/>

    <!-- Secondary: CTA / accent (indigo). -->
    <SolidColorBrush x:Key="Action.Secondary.Background" Color="{StaticResource Primitive.Indigo.600}"/>
    <SolidColorBrush x:Key="Action.Secondary.Hover"      Color="{StaticResource Primitive.Indigo.700}"/>
    <SolidColorBrush x:Key="Action.Secondary.Pressed"    Color="{StaticResource Primitive.Indigo.800}"/>

    <!-- Danger: destructive (red). -->
    <SolidColorBrush x:Key="Action.Danger.Background" Color="{StaticResource Primitive.Red.900}"/>
    <SolidColorBrush x:Key="Action.Danger.Hover"      Color="{StaticResource Primitive.Red.950}"/>
    <SolidColorBrush x:Key="Action.Danger.Pressed"    Color="{StaticResource Primitive.Red.950.Pressed}"/>

    <!-- Caption-close: distinct red used only on the title-bar X button.
         Different shade from Action.Danger so the chrome reads
         consistently with Windows close-button conventions. -->
    <SolidColorBrush x:Key="Action.CaptionClose.Hover"   Color="{StaticResource Primitive.Red.700.CaptionHover}"/>
    <SolidColorBrush x:Key="Action.CaptionClose.Pressed" Color="{StaticResource Primitive.Red.700.CaptionPressed}"/>

    <!-- Neutral: badges, dividers, low-emphasis fills. -->
    <SolidColorBrush x:Key="Action.Neutral" Color="{StaticResource Primitive.Slate.600}"/>

    <!-- Status. Outcome and state colours. Warning is imminent risk
         requiring user attention; Success is completion or positive
         outcome. -->
    <SolidColorBrush x:Key="Status.Warning" Color="{StaticResource Primitive.Amber.500}"/>
    <SolidColorBrush x:Key="Status.Success" Color="{StaticResource Primitive.Green.400}"/>

    <!-- Decoration. Brand-flavour icons. Distinct from Status colours
         so the two coexist on screen without semantic collision. Heart
         (Red.500 #ef4444) is 3.89:1 against Surface.Sidebar #1e293b,
         narrowly above the WCAG 1.4.11 non-text 3:1 threshold; the icon
         is decorative (AutomationProperties.Name carries the meaning)
         so the margin is acceptable. Brighten to Red.400 if a user
         reports trouble seeing the heart against the sidebar. -->
    <SolidColorBrush x:Key="Decoration.Heart" Color="{StaticResource Primitive.Red.500}"/>
    <SolidColorBrush x:Key="Decoration.Star"  Color="{StaticResource Primitive.Amber.400}"/>

    <!-- Links. Inline and default link tokens both resolve to full-
         opacity Indigo.400. A 66% alpha wash on Surface.Sidebar (the
         AboutWindow MIT licence link's home) measures 2.95:1 against
         background, below the WCAG AA-text 4.5:1 line; full opacity
         sits at 4.90:1. SubtleLink's hover-brighten remains the
         visual differentiation between in-body and full-weight
         links. -->
    <SolidColorBrush x:Key="Link.Default" Color="{StaticResource Primitive.Indigo.400}"/>
    <SolidColorBrush x:Key="Link.Inline"  Color="{StaticResource Primitive.Indigo.400}"/>

    <!-- Selection and scrollbar. -->
    <SolidColorBrush x:Key="Selection.Background"   Color="{StaticResource Primitive.Violet.700}"/>
    <SolidColorBrush x:Key="Scrollbar.Thumb"        Color="{StaticResource Primitive.Slate.50.Alpha20}"/>
    <SolidColorBrush x:Key="Scrollbar.Thumb.Hover"  Color="{StaticResource Primitive.Slate.50.Alpha50}"/>

    <!-- Typography. Six-step hierarchy. Each role is named for the
         job it does, not the size, so a size change edits the token
         instead of renaming consumers. -->
    <FontFamily x:Key="Type.FontFamily">pack://application:,,,/Fonts/#Poppins</FontFamily>

    <sys:Double x:Key="Type.Display">28</sys:Double>     <!-- splash hero -->
    <sys:Double x:Key="Type.Heading.Lg">22</sys:Double>  <!-- completion heading -->
    <sys:Double x:Key="Type.Heading.Md">20</sys:Double>  <!-- about title -->
    <sys:Double x:Key="Type.Heading.Sm">14</sys:Double>  <!-- window titles, status -->
    <sys:Double x:Key="Type.Body">12</sys:Double>        <!-- body copy, descriptions -->
    <sys:Double x:Key="Type.Caption">11</sys:Double>     <!-- metadata labels, footer -->

    <!-- Radius. Seven roles cover the app:
           Pill         - fully rounded 40 px action buttons.
           CompactPill  - fully rounded 30 px compact buttons.
           Card         - rounded cards and overlay containers.
           CardSm       - smaller rounded surfaces (splash card border).
           Inset        - card-within-a-card surfaces (JSON preview, etc.).
           Chip         - context menus, tooltips, list rows.
           Tight        - menu-item highlight chip. -->
    <CornerRadius x:Key="Radius.Pill">20</CornerRadius>
    <CornerRadius x:Key="Radius.CompactPill">15</CornerRadius>
    <CornerRadius x:Key="Radius.Card">16</CornerRadius>
    <CornerRadius x:Key="Radius.CardSm">12</CornerRadius>
    <CornerRadius x:Key="Radius.Inset">6</CornerRadius>
    <CornerRadius x:Key="Radius.Chip">4</CornerRadius>
    <CornerRadius x:Key="Radius.Tight">2</CornerRadius>

    <!-- Focus-visual radii. Derived geometry, not part of the Pill /
         Card / Chip ramp: a 40px pill with a -2px-margin focus ring
         needs 22 (Radius.Pill 20 + 2), and a 30px compact pill needs
         17 (15 + 2). Defined here so a future change to Radius.Pill
         updates the focus visual in lockstep. -->
    <CornerRadius x:Key="Radius.PillFocus">22</CornerRadius>
    <CornerRadius x:Key="Radius.CompactPillFocus">17</CornerRadius>

    <!-- Border thickness. Two flavours: the Double tokens are for
         properties that take a scalar (Path.StrokeThickness, etc);
         the Thickness tokens are for properties that take a
         Thickness struct (Border.BorderThickness,
         Control.BorderThickness). XAML resource lookups don't run
         the ThicknessConverter, so a Double resource cannot satisfy
         a Thickness setter; the mismatched key raises a
         XamlParseException the first time the consuming template is
         realised at runtime. -->
    <sys:Double x:Key="Border.None">0</sys:Double>
    <sys:Double x:Key="Border.Hairline">1</sys:Double>
    <sys:Double x:Key="Border.Standard">2</sys:Double>
    <sys:Double x:Key="Border.Heavy">4</sys:Double>
    <Thickness x:Key="BorderThickness.None">0</Thickness>
    <Thickness x:Key="BorderThickness.Hairline">1</Thickness>
    <Thickness x:Key="BorderThickness.Standard">2</Thickness>
    <Thickness x:Key="BorderThickness.Heavy">4</Thickness>

    <!-- Spacing. Thicknesses cover Margin/Padding sites. Directional
         (GapBottom, GapRight, GapLeft) for one-sided patterns;
         GapX for symmetric horizontal (both sides equal);
         multi-sided literal Margins stay for genuine one-offs. A
         scalar Spacing.* ramp earns a place only when a real Width /
         Height / scalar-Padding consumer surfaces. -->

    <Thickness x:Key="Gap.Lg">16</Thickness>

    <Thickness x:Key="GapBottom.Sm">0,0,0,8</Thickness>
    <Thickness x:Key="GapBottom.Md">0,0,0,12</Thickness>
    <Thickness x:Key="GapBottom.Lg">0,0,0,16</Thickness>
    <Thickness x:Key="GapBottom.Xl">0,0,0,24</Thickness>

    <Thickness x:Key="GapRight.Sm">0,0,8,0</Thickness>
    <Thickness x:Key="GapRight.Md">0,0,12,0</Thickness>
    <!-- Icon-after-text spacing: 6 sits below the 8/12/16/24 scale on
         purpose. A 12 to 18 px icon next to body text reads tightly at
         6 and slightly loose at 8; the irregular value names the
         pattern rather than hiding it as a literal in four window
         XAMLs. -->
    <Thickness x:Key="GapRight.Icon">0,0,6,0</Thickness>

    <Thickness x:Key="GapLeft.Md">12,0,0,0</Thickness>

    <!-- Horizontal-only gap (both sides). Used where an inline
         element wants equal left+right margin without affecting
         vertical layout. -->
    <Thickness x:Key="GapX.Md">12,0,12,0</Thickness>

    <!-- Outer margin shared by the detail windows (Orphaned, Registered,
         About) so they share a consistent inset. -->
    <Thickness x:Key="DetailWindowMargin">24,4,24,24</Thickness>

    <!-- Padding shared by the four modal-card Borders (ConfirmDelete,
         ConfirmMove, ConfirmSendResultLog, UpdateAvailable). The four
         modals also share Surface.Card, Radius.Card and the
         Action.Primary.Background outline; the 32,28 pair completes
         the card shape. -->
    <Thickness x:Key="Padding.ModalCard">32,28</Thickness>

    <!-- Main window content margin. The bottom value (48) matches the
         effective height of the bottom-nav DockPanel below (Row=3,
         Margin 4,8,24,8 around two 28-px-tall GhostPills); changing
         either side of that invariant requires the other side to
         follow or the content visually drifts behind the nav. -->
    <Thickness x:Key="MainContentMargin">24,0,24,48</Thickness>

    <!-- Negative top/right margin used by the detail-window caption-X
         close buttons (About, Registered, Orphaned). The -24 right
         component pulls the X out past DetailWindowMargin's 24 right
         component so the X sits at the window edge; the two move
         together. -->
    <Thickness x:Key="CloseButtonOverhangMargin">0,-4,-24,0</Thickness>

</ResourceDictionary>
