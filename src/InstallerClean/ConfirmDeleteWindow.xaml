<Window x:Class="InstallerClean.ConfirmDeleteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:InstallerClean.Resources"
        Title="{loc:Translate Window.ConfirmDelete.Title}"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" GlassFrameThickness="0"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource Surface.Card}" CornerRadius="{StaticResource Radius.Card}" Padding="32,28"
            MaxWidth="400" MinWidth="320"
            BorderBrush="{StaticResource Action.Primary.Background}" BorderThickness="1">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="{StaticResource GapBottom.Md}">
                <Path Data="M236.8,188.09,149.35,36.22h0a24.76,24.76,0,0,0-42.7,0L19.2,188.09a23.51,23.51,0,0,0,0,23.72A24.35,24.35,0,0,0,40.55,224h174.9a24.35,24.35,0,0,0,21.33-12.19A23.51,23.51,0,0,0,236.8,188.09ZM118,98a10,10,0,0,1,20,0v46a10,10,0,0,1,-20,0Zm10,96a14,14,0,1,1,14,-14A14,14,0,0,1,128,194Z"
                      Fill="{StaticResource Status.Warning}" Width="16" Height="16" Stretch="Uniform"
                      VerticalAlignment="Center" Margin="{StaticResource GapRight.Sm}"/>
                <TextBlock x:Name="MessageText" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Heading.Sm}"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock
                       Text="{loc:Translate Confirm.DeleteToRecycleBin}"
                       Foreground="{StaticResource Text.Muted}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"
                       Margin="{StaticResource GapBottom.Lg}"/>
            <TextBlock x:Name="LargeSizeWarning"
                       Text="{loc:Translate Confirm.DeleteLargeWarning}"
                       Foreground="{StaticResource Status.Warning}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"
                       Margin="0,-12,0,16" Visibility="Collapsed"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource GhostPill}" Content="{loc:Translate Action.Cancel}"
                        Click="OnCancel" IsCancel="True" Margin="{StaticResource GapRight.Sm}"/>
                <Button Style="{StaticResource DangerPill}" Content="{loc:Translate Action.Delete}" Click="OnDelete"
                        IsDefault="True"
                        AutomationProperties.HelpText="{loc:Translate Automation.ConfirmDelete}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
